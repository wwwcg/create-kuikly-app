import { KuiklyRenderView, KuiklyRenderCallback } from '@aspect/kuikly'

@Entry
@Component
struct Index {
  @State pageName: string = 'HelloWorld'

  build() {
    Column() {
      KuiklyRenderView({
        pageName: this.pageName,
        pageData: {},
        onPageResult: (result: KuiklyRenderCallback) => {}
      })
        .width('100%')
        .height('100%')
    }
    .width('100%')
    .height('100%')
  }
}
